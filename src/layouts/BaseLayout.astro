---
import { navigation, site } from '../lib/site';

interface Props {
	title?: string;
	description?: string;
}

const { title = site.name, description = site.description } = Astro.props;
const pageTitle = title === site.name ? title : `${title} | ${site.name}`;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{pageTitle}</title>
	</head>
	<body>
		<header class="site-header">
			<a class="brand" href="/" aria-label={`${site.name} home`}>
				<span>{site.name}</span>
				<small>{site.tagline}</small>
			</a>
			<nav aria-label="Primary navigation">
				{
					navigation.map((item) => (
						<a href={item.href} aria-current={Astro.url.pathname === item.href ? 'page' : undefined}>
							{item.label}
						</a>
					))
				}
			</nav>
		</header>
		<main>
			<slot />
		</main>
		<footer class="site-footer">
			<div>
				<strong>{site.name}</strong>
				<p>{site.tagline}</p>
			</div>
			<ul>
				<li><a href={`tel:${site.phone.replaceAll('-', '')}`}>{site.phone}</a></li>
				<li><a href={`mailto:${site.email}`}>{site.email}</a></li>
				<li>{site.address}</li>
			</ul>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		color-scheme: light;
		--ink: #1c1b1a;
		--muted: #69645f;
		--paper: #fffdf8;
		--panel: #f5f1e8;
		--line: #ded7c9;
		--accent: #8b2431;
		--accent-strong: #611520;
		--max: 1120px;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
		background: var(--paper);
		color: var(--ink);
	}

	* {
		box-sizing: border-box;
	}

	body {
		margin: 0;
		line-height: 1.6;
	}

	a {
		color: var(--accent-strong);
		text-decoration-thickness: 0.08em;
		text-underline-offset: 0.18em;
	}

	img {
		display: block;
		max-width: 100%;
		height: auto;
	}

	.site-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		max-width: var(--max);
		margin: 0 auto;
		padding: 1.1rem 1.25rem;
		border-bottom: 1px solid var(--line);
	}

	.brand {
		display: grid;
		gap: 0.05rem;
		color: var(--ink);
		text-decoration: none;
	}

	.brand span {
		font-weight: 800;
		font-size: 1.05rem;
	}

	.brand small {
		color: var(--muted);
		font-size: 0.82rem;
	}

	nav {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 0.35rem 0.85rem;
		font-size: 0.93rem;
	}

	nav a {
		color: var(--ink);
		text-decoration: none;
	}

	nav a[aria-current='page'] {
		color: var(--accent);
		font-weight: 700;
	}

	main {
		min-height: 60vh;
	}

	.hero {
		background: linear-gradient(135deg, #fffdf8 0%, #f3eadc 58%, #e7eef1 100%);
		border-bottom: 1px solid var(--line);
	}

	.hero-inner,
	.section,
	.content-page,
	.site-footer {
		max-width: var(--max);
		margin: 0 auto;
		padding: 4rem 1.25rem;
	}

	.hero-inner {
		display: grid;
		grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.85fr);
		gap: 2.5rem;
		align-items: center;
		min-height: 520px;
	}

	.kicker {
		margin: 0 0 0.8rem;
		color: var(--accent);
		font-weight: 800;
		text-transform: uppercase;
		font-size: 0.78rem;
		letter-spacing: 0.08em;
	}

	h1,
	h2,
	h3 {
		line-height: 1.12;
		margin: 0 0 1rem;
	}

	h1 {
		font-size: clamp(2.5rem, 8vw, 5.4rem);
		max-width: 10ch;
	}

	h2 {
		font-size: clamp(1.8rem, 4vw, 3rem);
	}

	h3 {
		font-size: 1.25rem;
	}

	p {
		margin: 0 0 1rem;
	}

	.lede {
		color: var(--muted);
		font-size: clamp(1.08rem, 2vw, 1.28rem);
		max-width: 62ch;
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin-top: 1.8rem;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 44px;
		padding: 0.72rem 1rem;
		border: 1px solid var(--accent);
		border-radius: 6px;
		background: var(--accent);
		color: #fff;
		font-weight: 800;
		text-decoration: none;
	}

	.button.secondary {
		background: transparent;
		color: var(--accent-strong);
	}

	.hero-panel,
	.callout {
		border: 1px solid var(--line);
		border-radius: 8px;
		background: rgba(255, 253, 248, 0.78);
		padding: 1.25rem;
	}

	.fact-list,
	.site-footer ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.fact-list li {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.85rem 0;
		border-bottom: 1px solid var(--line);
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.card {
		border: 1px solid var(--line);
		border-radius: 8px;
		background: #fff;
		padding: 1.2rem;
	}

	.band {
		background: var(--panel);
		border-block: 1px solid var(--line);
	}

	.content-page {
		max-width: 820px;
	}

	.content-page > header {
		margin-bottom: 2rem;
	}

	.content-page article :is(h2, h3) {
		margin-top: 2rem;
	}

	.content-page article :is(p, li) {
		color: #37332f;
	}

	.post-list {
		display: grid;
		gap: 1rem;
		list-style: none;
		padding: 0;
	}

	.site-footer {
		display: flex;
		justify-content: space-between;
		gap: 2rem;
		border-top: 1px solid var(--line);
		color: var(--muted);
	}

	@media (max-width: 820px) {
		.site-header,
		.site-footer,
		.hero-inner {
			display: grid;
		}

		nav {
			justify-content: flex-start;
		}

		.hero-inner {
			grid-template-columns: 1fr;
			min-height: auto;
			padding-block: 3rem;
		}

		.grid {
			grid-template-columns: 1fr;
		}
	}
</style>
