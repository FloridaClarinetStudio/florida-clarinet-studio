---
import { Icon } from 'astro-icon/components';
import { footerNavigation, navigation, site } from '../lib/site';
import { absoluteUrl, buildJsonLd, canonicalUrl, fullTitle } from '../lib/seo';

interface Props {
	title?: string;
	description?: string;
	image?: {
		src: string;
		alt?: string;
	};
	type?: 'website' | 'article';
	publishedTime?: Date;
	modifiedTime?: Date;
	noindex?: boolean;
	jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
	title = site.name,
	description = site.description,
	image = { src: site.defaultImage, alt: site.tagline },
	type = 'website',
	publishedTime,
	modifiedTime,
	noindex = false,
	jsonLd,
} = Astro.props;
const pageTitle = fullTitle(title);
const canonical = canonicalUrl(Astro.url);
const imageUrl = absoluteUrl(image.src);
const structuredData = buildJsonLd({
	title: pageTitle,
	description,
	url: Astro.url,
	image,
	type,
	publishedTime,
	modifiedTime,
	jsonLd,
});

const footerLinks = [
	{
		href: `tel:${site.phone.replaceAll('-', '')}`,
		label: site.phone,
		icon: 'phone',
	},
	{
		href: `mailto:${site.email}`,
		label: site.email,
		icon: 'mail',
	},
	{ href: site.social.facebook, label: 'Facebook', icon: 'facebook', external: true },
	{ href: site.social.instagram, label: 'Instagram', icon: 'instagram', external: true },
	{ href: site.social.linkedin, label: 'LinkedIn', icon: 'linkedin', external: true },
	{ href: site.social.tiktok, label: 'TikTok', icon: 'tiktok', external: true },
	{ href: site.social.twitter, label: 'X', icon: 'x', external: true },
	{ href: site.social.youtube, label: 'YouTube', icon: 'youtube', external: true },
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href={site.logo} />
		<link rel="icon" type="image/png" sizes="192x192" href={site.logo} />
		<link rel="apple-touch-icon" href={site.logo} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large'} />
		<meta name="author" content="Robin Ryon" />
		<meta name="theme-color" content="#fffaf0" />
		<link rel="canonical" href={canonical} />
		<link rel="alternate" type="text/markdown" href="/llms.txt" title={`${site.name} AI content index`} />
		<link rel="alternate" type="text/markdown" href="/llms-full.txt" title={`${site.name} full Markdown content`} />
		<link rel="preload" as="image" href={image.src} fetchpriority="high" />
		<meta property="og:site_name" content={site.name} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content={type} />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content={imageUrl} />
		<meta property="og:image:alt" content={image.alt ?? title} />
		<meta property="og:locale" content="en_US" />
		{publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}
		{modifiedTime && <meta property="article:modified_time" content={modifiedTime.toISOString()} />}
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={imageUrl} />
		<meta name="twitter:image:alt" content={image.alt ?? title} />
		<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
		<title>{pageTitle}</title>
	</head>
	<body>
		<header class="site-header">
			<a class="brand" href="/" aria-label={`${site.name} home`}>
				<img src={site.logo} alt="" width="44" height="44" />
				<span>
					<strong>{site.name}</strong>
					<small>{site.tagline}</small>
				</span>
			</a>
			<nav aria-label="Primary navigation">
				{
					navigation.map((item) => (
						<a href={item.href} aria-current={Astro.url.pathname === item.href ? 'page' : undefined}>
							{item.label}
						</a>
					))
				}
			</nav>
		</header>
		<main>
			<slot />
		</main>
		<footer class="site-footer">
			<div>
				<strong>{site.name}</strong>
				<p>{site.tagline}</p>
				<a class="button footer-button" href="/contact-us/">{site.primaryCta}</a>
			</div>
			<nav class="footer-nav" aria-label="Footer resources">
				<strong>Resources</strong>
				<ul>
					{
						footerNavigation.map((item) => (
							<li>
								<a href={item.href} aria-current={Astro.url.pathname === item.href ? 'page' : undefined}>
									{item.label}
								</a>
							</li>
						))
					}
				</ul>
			</nav>
			<ul>
				{
					footerLinks.map((link) => (
						<li>
							<a
								href={link.href}
								rel={link.external ? 'me noopener' : undefined}
								target={link.external ? '_blank' : undefined}
							>
								<span class="footer-icon" aria-hidden="true">
									<Icon name={link.icon} />
								</span>
								<span>{link.label}</span>
							</a>
						</li>
					))
				}
				<li class="footer-address">
					<span class="footer-icon" aria-hidden="true">
						<Icon name="map-pin" />
					</span>
					<span>{site.address}</span>
				</li>
			</ul>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		color-scheme: light;
		--ink: #191511;
		--muted: #675f56;
		--paper: #fffaf0;
		--panel: #f2eadc;
		--line: #dccdb9;
		--accent: #a7353f;
		--accent-strong: #71202a;
		--teal: #2d6870;
		--moss: #64733d;
		--gold: #c68a2c;
		--charcoal: #201816;
		--max: 1180px;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
		background: var(--paper);
		color: var(--ink);
	}

	* {
		box-sizing: border-box;
	}

	body {
		margin: 0;
		line-height: 1.6;
		background:
			linear-gradient(90deg, rgba(167, 53, 63, 0.055) 1px, transparent 1px),
			linear-gradient(180deg, rgba(45, 104, 112, 0.045) 1px, transparent 1px),
			var(--paper);
		background-size: 48px 48px;
	}

	a {
		color: var(--accent-strong);
		text-decoration-thickness: 0.08em;
		text-underline-offset: 0.18em;
	}

	img {
		display: block;
		max-width: 100%;
		height: auto;
	}

	.site-header {
		position: sticky;
		top: 0;
		z-index: 10;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		width: min(calc(100% - 2rem), var(--max));
		margin: 1rem auto 0;
		padding: 0.78rem 1rem;
		border: 1px solid rgba(255, 255, 255, 0.42);
		border-radius: 8px;
		background: rgba(255, 250, 240, 0.88);
		box-shadow: 0 18px 55px rgba(40, 27, 18, 0.13);
		backdrop-filter: blur(18px);
	}

	.brand {
		display: flex;
		align-items: center;
		gap: 0.7rem;
		color: var(--ink);
		text-decoration: none;
	}

	.brand img {
		width: 44px;
		height: 44px;
		object-fit: contain;
		flex: 0 0 auto;
	}

	.brand span {
		display: grid;
		gap: 0.05rem;
	}

	.brand strong {
		font-weight: 800;
		font-size: 1rem;
	}

	.brand small {
		color: var(--muted);
		font-size: 0.82rem;
	}

	nav {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 0.35rem 0.7rem;
		font-size: 0.9rem;
	}

	nav a {
		color: var(--ink);
		text-decoration: none;
	}

	nav a[aria-current='page'] {
		color: var(--accent);
		font-weight: 700;
	}

	main {
		min-height: 60vh;
	}

	.hero {
		margin-top: -5.6rem;
		background:
			linear-gradient(90deg, rgba(20, 13, 10, 0.78) 0%, rgba(27, 18, 14, 0.6) 42%, rgba(27, 18, 14, 0.05) 100%),
			image-set(url('/images/original/instruments.jpg') 1x);
		background-position: center;
		background-size: cover;
		border-bottom: 1px solid var(--line);
		color: #fff8ec;
	}

	.hero-inner,
	.section,
	.content-page,
	.site-footer {
		max-width: var(--max);
		margin: 0 auto;
		padding: 4rem 1.25rem;
	}

	.hero-inner {
		display: grid;
		grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.85fr);
		gap: 2.5rem;
		align-items: center;
		min-height: min(760px, 92vh);
		padding-top: 8.4rem;
	}

	.kicker {
		margin: 0 0 0.8rem;
		color: var(--accent);
		font-weight: 800;
		text-transform: uppercase;
		font-size: 0.78rem;
		letter-spacing: 0.08em;
	}

	h1,
	h2,
	h3 {
		line-height: 1.12;
		margin: 0 0 1rem;
	}

	h1 {
		font-size: clamp(2.5rem, 8vw, 5.4rem);
		max-width: 10ch;
	}

	h2 {
		font-size: clamp(1.8rem, 4vw, 3rem);
	}

	h3 {
		font-size: 1.25rem;
	}

	p {
		margin: 0 0 1rem;
	}

	.lede {
		color: var(--muted);
		font-size: clamp(1.08rem, 2vw, 1.28rem);
		max-width: 62ch;
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin-top: 1.8rem;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 44px;
		padding: 0.72rem 1rem;
		border: 1px solid var(--accent);
		border-radius: 6px;
		background: var(--accent);
		color: #fff;
		font-weight: 800;
		text-decoration: none;
	}

	.button.secondary {
		background: transparent;
		color: var(--accent-strong);
		border-color: var(--accent);
	}

	.hero-panel,
	.callout {
		border: 1px solid var(--line);
		border-radius: 8px;
		background: rgba(255, 253, 248, 0.78);
		padding: 1.25rem;
	}

	.hero .kicker,
	.hero .lede {
		color: #ffe0ae;
	}

	.hero .hero-panel {
		align-self: end;
		background: rgba(255, 250, 240, 0.92);
		color: var(--ink);
		box-shadow: 0 24px 80px rgba(0, 0, 0, 0.28);
	}

	.hero .hero-panel .kicker {
		color: var(--accent-strong);
	}

	.hero-portrait {
		width: 100%;
		aspect-ratio: 1 / 1;
		object-fit: cover;
		object-position: center top;
		border-radius: 6px;
		margin-bottom: 1rem;
	}

	.hero .button.secondary,
	.feature-band .button.secondary {
		background: rgba(255, 255, 255, 0.1);
		color: inherit;
		border-color: rgba(255, 255, 255, 0.52);
	}

	.fact-list,
	.site-footer ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.fact-list li {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.85rem 0;
		border-bottom: 1px solid var(--line);
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.card {
		border: 1px solid var(--line);
		border-radius: 8px;
		background: #fff;
		padding: 1.2rem;
		box-shadow: 0 18px 50px rgba(52, 37, 24, 0.08);
	}

	.photo-card {
		overflow: hidden;
		padding: 0;
	}

	.photo-card img {
		width: 100%;
		aspect-ratio: 4 / 3;
		object-fit: cover;
	}

	.photo-card > div {
		padding: 1.2rem;
	}

	.listening-grid {
		grid-template-columns: repeat(2, minmax(180px, 1fr));
		align-items: start;
	}

	.proof-grid,
	.price-grid,
	.quote-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.price-grid {
		grid-template-columns: 1fr;
	}

	.proof-card,
	.price-card {
		box-shadow: none;
	}

	.proof-card h3,
	.price-card h3 {
		font-size: 1.15rem;
	}

	.testimonial-band {
		border: 1px solid var(--line);
		border-radius: 8px;
		background: #fff;
		padding: clamp(1.25rem, 4vw, 2rem);
		box-shadow: 0 18px 50px rgba(52, 37, 24, 0.08);
	}

	blockquote {
		margin: 0;
		border-left: 4px solid var(--gold);
		padding: 0.25rem 0 0.25rem 1rem;
		color: var(--muted);
	}

	.listening-card {
		color: var(--ink);
	}

	.listening-card img {
		aspect-ratio: 1 / 1;
		object-position: top center;
	}

	.listening-card h3 {
		color: var(--ink);
	}

	.listening-card p {
		color: var(--muted);
	}

	.split {
		display: grid;
		grid-template-columns: minmax(0, 0.95fr) minmax(300px, 1.05fr);
		gap: 2rem;
		align-items: center;
	}

	.section-intro {
		max-width: 900px;
	}

	.image-stack {
		display: grid;
		grid-template-columns: 0.8fr 1fr;
		gap: 0.8rem;
		align-items: end;
	}

	.image-stack img {
		width: 100%;
		object-fit: cover;
		border-radius: 8px;
		box-shadow: 0 20px 60px rgba(31, 20, 13, 0.18);
	}

	.image-stack img:first-child {
		aspect-ratio: 3 / 4;
	}

	.image-stack img:last-child {
		aspect-ratio: 4 / 3;
		transform: translateY(-2rem);
	}

	.stat-strip {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1px;
		margin-top: -1px;
		background: var(--line);
		border-block: 1px solid var(--line);
	}

	.stat-strip div {
		background: #fff7e8;
		padding: 1.1rem 1.25rem;
	}

	.stat-strip strong {
		display: block;
		color: var(--accent-strong);
		font-size: 1.35rem;
		line-height: 1;
	}

	.feature-band {
		background: var(--charcoal);
		color: #fff8ec;
	}

	.feature-band .lede,
	.feature-band p {
		color: #e6d5bf;
	}

	.feature-band .card {
		color: var(--ink);
	}

	.feature-band .card h3 {
		color: var(--ink);
	}

	.feature-band .card p {
		color: var(--muted);
	}

	.band {
		background: var(--panel);
		border-block: 1px solid var(--line);
	}

	.content-page {
		max-width: 820px;
	}

	.page-hero {
		position: relative;
		min-height: 420px;
		margin-top: -5.6rem;
		color: #fff8ec;
		background: var(--charcoal);
		overflow: hidden;
	}

	.page-hero img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		opacity: 0.52;
	}

	.page-hero::after {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(90deg, rgba(20, 13, 10, 0.86), rgba(20, 13, 10, 0.4), rgba(20, 13, 10, 0.08));
	}

	.page-hero-content {
		position: relative;
		z-index: 1;
		max-width: var(--max);
		margin: 0 auto;
		padding: 9rem 1.25rem 4rem;
	}

	.page-hero .lede,
	.page-hero .kicker {
		color: #ffe0ae;
	}

	.recommendation-hero {
		min-height: clamp(560px, 70vh, 720px);
		background: #211711;
	}

	.recommendation-hero::after {
		display: none;
	}

	.recommendation-hero .page-hero-content {
		display: grid;
		grid-template-columns: minmax(0, 0.92fr) minmax(320px, 0.72fr);
		gap: clamp(2rem, 5vw, 5rem);
		align-items: center;
		padding-block: 10rem 5rem;
	}

	.recommendation-copy {
		max-width: 680px;
	}

	.recommendation-image {
		margin: 0;
		justify-self: end;
		width: min(100%, 520px);
		aspect-ratio: 1 / 1;
		border: 1px solid rgba(255, 224, 174, 0.24);
		border-radius: 8px;
		background: #fffaf1;
		box-shadow: 0 2rem 4rem rgba(0, 0, 0, 0.32);
		overflow: hidden;
	}

	.recommendation-hero .recommendation-image img {
		position: static;
		width: 100%;
		height: 100%;
		object-fit: contain;
		opacity: 1;
	}

	@media (max-width: 820px) {
		.recommendation-hero .page-hero-content {
			grid-template-columns: 1fr;
			padding-block: 8.5rem 3rem;
		}

		.recommendation-image {
			justify-self: start;
			width: min(100%, 420px);
		}
	}

	.content-page > header {
		margin-bottom: 2rem;
	}

	.content-page article :is(h2, h3) {
		margin-top: 2rem;
	}

	.content-page article :is(p, li) {
		color: #37332f;
	}

	.content-image {
		margin: 1.5rem 0 2rem;
	}

	.content-image img {
		width: 100%;
		aspect-ratio: 16 / 9;
		object-fit: cover;
		border-radius: 8px;
		box-shadow: 0 18px 50px rgba(52, 37, 24, 0.14);
	}

	.content-image.portrait {
		max-width: 520px;
	}

	.content-image.portrait img {
		aspect-ratio: auto;
		object-fit: contain;
	}

	.content-image figcaption {
		margin-top: 0.55rem;
		color: var(--muted);
		font-size: 0.92rem;
	}

	.contact-layout {
		display: grid;
		grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.85fr);
		gap: 1.25rem;
		align-items: start;
		margin-top: 2rem;
	}

	.contact-form,
	.contact-details {
		border: 1px solid var(--line);
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.78);
		box-shadow: 0 18px 50px rgba(52, 37, 24, 0.08);
	}

	.contact-form {
		display: grid;
		gap: 1rem;
		padding: 1.25rem;
	}

	.form-row {
		display: grid;
		gap: 0.4rem;
	}

	label {
		color: var(--ink);
		font-weight: 800;
	}

	input,
	select,
	textarea {
		width: 100%;
		border: 1px solid var(--line);
		border-radius: 6px;
		background: #fffdf8;
		color: var(--ink);
		font: inherit;
		padding: 0.72rem 0.8rem;
	}

	textarea {
		resize: vertical;
	}

	input:focus,
	select:focus,
	textarea:focus {
		outline: 3px solid rgba(167, 53, 63, 0.2);
		border-color: var(--accent);
	}

	.hidden-field {
		display: none;
	}

	.contact-details {
		padding: 1.25rem;
	}

	.contact-details h2 {
		font-size: 1.25rem;
		margin-top: 0;
	}

	.contact-details ul {
		display: grid;
		gap: 0.9rem;
		padding: 0;
		margin: 0 0 1.5rem;
		list-style: none;
	}

	.contact-details li {
		display: grid;
		gap: 0.15rem;
		color: var(--muted);
	}

	.contact-details strong {
		color: var(--ink);
	}

	.thank-you-page {
		min-height: 60vh;
		display: grid;
		align-content: center;
	}

	.post-list {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.5rem;
		list-style: none;
		padding: 0;
	}

	.blog-page {
		max-width: var(--max);
	}

	.blog-page > header {
		max-width: 760px;
		margin-bottom: 2.5rem;
	}

	.post-list .photo-card > div {
		display: grid;
		align-content: start;
		gap: 0.8rem;
		padding: 1.35rem;
	}

	.post-list .photo-card h2 {
		font-size: clamp(1.25rem, 2vw, 1.65rem);
		margin-bottom: 0;
	}

	.post-list .photo-card p {
		margin-bottom: 0;
	}

	.post-list .photo-card img {
		aspect-ratio: 16 / 10;
		object-fit: contain;
		background: #fffdf8;
		padding: 1rem;
	}

	.product-name {
		color: var(--accent-strong);
		font-weight: 800;
	}

	.recommendation-card .actions {
		margin-top: 0.4rem;
	}

	.compact-actions {
		gap: 0.55rem;
	}

	.compact-actions .button {
		min-height: 40px;
		padding: 0.58rem 0.8rem;
		font-size: 0.9rem;
	}

	.site-footer {
		display: grid;
