---
import { navigation, site } from '../lib/site';

interface Props {
	title?: string;
	description?: string;
}

const { title = site.name, description = site.description } = Astro.props;
const pageTitle = title === site.name ? title : `${title} | ${site.name}`;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link rel="preload" as="image" href="/images/original/instruments.jpg" />
		<title>{pageTitle}</title>
	</head>
	<body>
		<header class="site-header">
			<a class="brand" href="/" aria-label={`${site.name} home`}>
				<span>{site.name}</span>
				<small>{site.tagline}</small>
			</a>
			<nav aria-label="Primary navigation">
				{
					navigation.map((item) => (
						<a href={item.href} aria-current={Astro.url.pathname === item.href ? 'page' : undefined}>
							{item.label}
						</a>
					))
				}
			</nav>
		</header>
		<main>
			<slot />
		</main>
		<footer class="site-footer">
			<div>
				<strong>{site.name}</strong>
				<p>{site.tagline}</p>
			</div>
			<ul>
				<li><a href={`tel:${site.phone.replaceAll('-', '')}`}>{site.phone}</a></li>
				<li><a href={`mailto:${site.email}`}>{site.email}</a></li>
				<li>{site.address}</li>
			</ul>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		color-scheme: light;
		--ink: #191511;
		--muted: #675f56;
		--paper: #fffaf0;
		--panel: #f2eadc;
		--line: #dccdb9;
		--accent: #a7353f;
		--accent-strong: #71202a;
		--teal: #2d6870;
		--moss: #64733d;
		--gold: #c68a2c;
		--charcoal: #201816;
		--max: 1180px;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
		background: var(--paper);
		color: var(--ink);
	}

	* {
		box-sizing: border-box;
	}

	body {
		margin: 0;
		line-height: 1.6;
		background:
			linear-gradient(90deg, rgba(167, 53, 63, 0.055) 1px, transparent 1px),
			linear-gradient(180deg, rgba(45, 104, 112, 0.045) 1px, transparent 1px),
			var(--paper);
		background-size: 48px 48px;
	}

	a {
		color: var(--accent-strong);
		text-decoration-thickness: 0.08em;
		text-underline-offset: 0.18em;
	}

	img {
		display: block;
		max-width: 100%;
		height: auto;
	}

	.site-header {
		position: sticky;
		top: 0;
		z-index: 10;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		width: min(calc(100% - 2rem), var(--max));
		margin: 1rem auto 0;
		padding: 0.78rem 1rem;
		border: 1px solid rgba(255, 255, 255, 0.42);
		border-radius: 8px;
		background: rgba(255, 250, 240, 0.88);
		box-shadow: 0 18px 55px rgba(40, 27, 18, 0.13);
		backdrop-filter: blur(18px);
	}

	.brand {
		display: grid;
		gap: 0.05rem;
		color: var(--ink);
		text-decoration: none;
	}

	.brand span {
		font-weight: 800;
		font-size: 1rem;
	}

	.brand small {
		color: var(--muted);
		font-size: 0.82rem;
	}

	nav {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 0.35rem 0.7rem;
		font-size: 0.9rem;
	}

	nav a {
		color: var(--ink);
		text-decoration: none;
	}

	nav a[aria-current='page'] {
		color: var(--accent);
		font-weight: 700;
	}

	main {
		min-height: 60vh;
	}

	.hero {
		margin-top: -5.6rem;
		background:
			linear-gradient(90deg, rgba(20, 13, 10, 0.78) 0%, rgba(27, 18, 14, 0.6) 42%, rgba(27, 18, 14, 0.05) 100%),
			image-set(url('/images/original/instruments.jpg') 1x);
		background-position: center;
		background-size: cover;
		border-bottom: 1px solid var(--line);
		color: #fff8ec;
	}

	.hero-inner,
	.section,
	.content-page,
	.site-footer {
		max-width: var(--max);
		margin: 0 auto;
		padding: 4rem 1.25rem;
	}

	.hero-inner {
		display: grid;
		grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.85fr);
		gap: 2.5rem;
		align-items: center;
		min-height: min(760px, 92vh);
		padding-top: 8.4rem;
	}

	.kicker {
		margin: 0 0 0.8rem;
		color: var(--accent);
		font-weight: 800;
		text-transform: uppercase;
		font-size: 0.78rem;
		letter-spacing: 0.08em;
	}

	h1,
	h2,
	h3 {
		line-height: 1.12;
		margin: 0 0 1rem;
	}

	h1 {
		font-size: clamp(2.5rem, 8vw, 5.4rem);
		max-width: 10ch;
	}

	h2 {
		font-size: clamp(1.8rem, 4vw, 3rem);
	}

	h3 {
		font-size: 1.25rem;
	}

	p {
		margin: 0 0 1rem;
	}

	.lede {
		color: var(--muted);
		font-size: clamp(1.08rem, 2vw, 1.28rem);
		max-width: 62ch;
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin-top: 1.8rem;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 44px;
		padding: 0.72rem 1rem;
		border: 1px solid var(--accent);
		border-radius: 6px;
		background: var(--accent);
		color: #fff;
		font-weight: 800;
		text-decoration: none;
	}

	.button.secondary {
		background: transparent;
		color: var(--accent-strong);
		border-color: var(--accent);
	}

	.hero-panel,
	.callout {
		border: 1px solid var(--line);
		border-radius: 8px;
		background: rgba(255, 253, 248, 0.78);
		padding: 1.25rem;
	}

	.hero .kicker,
	.hero .lede {
		color: #ffe0ae;
	}

	.hero .hero-panel {
		align-self: end;
		background: rgba(255, 250, 240, 0.92);
		color: var(--ink);
		box-shadow: 0 24px 80px rgba(0, 0, 0, 0.28);
	}

	.hero .hero-panel .kicker {
		color: var(--accent-strong);
	}

	.hero .button.secondary,
	.feature-band .button.secondary {
		background: rgba(255, 255, 255, 0.1);
		color: inherit;
		border-color: rgba(255, 255, 255, 0.52);
	}

	.fact-list,
	.site-footer ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.fact-list li {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.85rem 0;
		border-bottom: 1px solid var(--line);
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.card {
		border: 1px solid var(--line);
		border-radius: 8px;
		background: #fff;
		padding: 1.2rem;
		box-shadow: 0 18px 50px rgba(52, 37, 24, 0.08);
	}

	.photo-card {
		overflow: hidden;
		padding: 0;
	}

	.photo-card img {
		width: 100%;
		aspect-ratio: 4 / 3;
		object-fit: cover;
	}

	.photo-card > div {
		padding: 1.2rem;
	}

	.listening-grid {
		grid-template-columns: repeat(2, minmax(180px, 1fr));
		align-items: start;
	}

	.listening-card {
		color: var(--ink);
	}

	.listening-card img {
		aspect-ratio: 1 / 1;
		object-position: top center;
	}

	.listening-card h3 {
		color: var(--ink);
	}

	.listening-card p {
		color: var(--muted);
	}

	.split {
		display: grid;
		grid-template-columns: minmax(0, 0.95fr) minmax(300px, 1.05fr);
		gap: 2rem;
		align-items: center;
	}

	.section-intro {
		max-width: 900px;
	}

	.image-stack {
		display: grid;
		grid-template-columns: 0.8fr 1fr;
		gap: 0.8rem;
		align-items: end;
	}

	.image-stack img {
		width: 100%;
		object-fit: cover;
		border-radius: 8px;
		box-shadow: 0 20px 60px rgba(31, 20, 13, 0.18);
	}

	.image-stack img:first-child {
		aspect-ratio: 3 / 4;
	}

	.image-stack img:last-child {
		aspect-ratio: 4 / 3;
		transform: translateY(-2rem);
	}

	.stat-strip {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1px;
		margin-top: -1px;
		background: var(--line);
		border-block: 1px solid var(--line);
	}

	.stat-strip div {
		background: #fff7e8;
		padding: 1.1rem 1.25rem;
	}

	.stat-strip strong {
		display: block;
		color: var(--accent-strong);
		font-size: 1.35rem;
		line-height: 1;
	}

	.feature-band {
		background: var(--charcoal);
		color: #fff8ec;
	}

	.feature-band .lede,
	.feature-band p {
		color: #e6d5bf;
	}

	.feature-band .card {
		color: var(--ink);
	}

	.feature-band .card h3 {
		color: var(--ink);
	}

	.feature-band .card p {
		color: var(--muted);
	}

	.band {
		background: var(--panel);
		border-block: 1px solid var(--line);
	}

	.content-page {
		max-width: 820px;
	}

	.page-hero {
		position: relative;
		min-height: 420px;
		margin-top: -5.6rem;
		color: #fff8ec;
		background: var(--charcoal);
		overflow: hidden;
	}

	.page-hero img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		opacity: 0.52;
	}

	.page-hero::after {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(90deg, rgba(20, 13, 10, 0.86), rgba(20, 13, 10, 0.4), rgba(20, 13, 10, 0.08));
	}

	.page-hero-content {
		position: relative;
		z-index: 1;
		max-width: var(--max);
		margin: 0 auto;
		padding: 9rem 1.25rem 4rem;
	}

	.page-hero .lede,
	.page-hero .kicker {
		color: #ffe0ae;
	}

	.content-page > header {
		margin-bottom: 2rem;
	}

	.content-page article :is(h2, h3) {
		margin-top: 2rem;
	}

	.content-page article :is(p, li) {
		color: #37332f;
	}

	.content-image {
		margin: 1.5rem 0 2rem;
	}

	.content-image img {
		width: 100%;
		aspect-ratio: 16 / 9;
		object-fit: cover;
		border-radius: 8px;
		box-shadow: 0 18px 50px rgba(52, 37, 24, 0.14);
	}

	.content-image figcaption {
		margin-top: 0.55rem;
		color: var(--muted);
		font-size: 0.92rem;
	}

	.post-list {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		list-style: none;
		padding: 0;
	}

	.site-footer {
		display: flex;
		justify-content: space-between;
		gap: 2rem;
		border-top: 1px solid var(--line);
		color: #e6d5bf;
		background: var(--charcoal);
		max-width: none;
		padding-inline: max(1.25rem, calc((100vw - var(--max)) / 2));
	}

	.site-footer a {
		color: #ffe0ae;
	}

	@media (max-width: 820px) {
		.site-header,
		.site-footer,
		.hero-inner {
			display: grid;
		}

		nav {
			justify-content: flex-start;
		}

		.hero-inner {
			grid-template-columns: 1fr;
			min-height: auto;
			padding-block: 8rem 3rem;
		}

		.grid,
		.post-list,
		.stat-strip,
		.split {
			grid-template-columns: 1fr;
		}

		.image-stack {
			grid-template-columns: 1fr;
		}

		.image-stack img:last-child {
			transform: none;
		}
	}
</style>
