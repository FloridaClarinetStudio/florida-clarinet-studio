---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { blogImages, images } from '../../lib/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const postsWithImages = posts.map((post) => {
	const slug = post.id.replace(/\.(md|mdx)$/, '');
	return {
		post,
		slug,
		image: blogImages[slug as keyof typeof blogImages] ?? images.studioCase,
	};
});
---

<BaseLayout title="Blog" description="Advice, gear notes, listening recommendations, and studio updates.">
	<section class="content-page">
		<header>
			<p class="kicker">Studio Notes</p>
			<h1>Blog</h1>
			<p class="lede">Advice, recommendations, and updates from Florida Clarinet Studio.</p>
		</header>
		<ul class="post-list">
			{
				postsWithImages.map(({ post, slug, image }) => (
					<li class="card photo-card">
						<img src={image.src} alt={image.alt} loading="lazy" />
						<div>
							<h2><a href={`/blog/${slug}/`}>{post.data.title}</a></h2>
							<p>{post.data.description}</p>
							<small>{post.data.pubDate.toLocaleDateString('en-US')}</small>
						</div>
					</li>
				))
			}
		</ul>
	</section>
</BaseLayout>
