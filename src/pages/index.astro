---
import { Icon } from 'astro-icon/components';
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { images, site } from '../lib/site';

const home = await getEntry('pages', 'home');
const Content = home ? (await render(home)).Content : undefined;
const socialProof = [
	{
		href: site.social.instagram,
		icon: 'instagram',
		label: 'Instagram',
	},
	{
		href: site.social.tiktok,
		icon: 'tiktok',
		label: 'TikTok',
	},
];
---

<BaseLayout title={site.name} description={home?.data.description ?? site.description} image={images.instruments}>
	<section class="hero">
		<div class="hero-inner">
			<div>
				<p class="kicker">Melbourne, Palm Bay, Viera, and the Space Coast of Central Florida</p>
				<div class="hero-social-proof" aria-label="Florida Clarinet Studio social follower counts">
					{
						socialProof.map((item) => (
							<a href={item.href} target="_blank" rel="me noopener">
								<Icon name={item.icon} />
								<span>{item.label}</span>
							</a>
						))
					}
				</div>
				<h1>Private clarinet and saxophone lessons with a higher ceiling.</h1>
				<p class="lede">
					Robin Ryon helps Space Coast students build stronger sound, sharper auditions,
					and the personal discipline and confidence to thrive in school band,
					All-County, All-State, solo and ensemble, and beyond.
				</p>
				<div class="actions">
					<a class="button" href="/contact-us/">{site.primaryCta}</a>
					<a class="button secondary" href="/contact-us/">Contact Robin</a>
				</div>
			</div>
			<aside class="hero-panel" aria-label="Robin Ryon contact information">
				<img class="hero-portrait" src={images.mrRyon.src} alt={images.mrRyon.alt} loading="eager" />
				<p class="kicker">Meet Robin Ryon</p>
				<h2>One teacher, a clear plan, and a lot of care.</h2>
				<ul class="fact-list">
					<li><span>Phone</span><strong>{site.phone}</strong></li>
					<li><span>Location</span><strong>Palm Bay, FL</strong></li>
					<li><span>Formats</span><strong>Palm Bay, travel, online</strong></li>
					<li><span>Focus</span><strong>Auditions, tone, discipline</strong></li>
				</ul>
			</aside>
		</div>
	</section>

	<section class="stat-strip" aria-label="Robin Ryon teaching highlights">
		<div><strong>Almost 40</strong><span>years of teaching and playing experience</span></div>
		<div><strong>Over $350k</strong><span>in scholarship monies awarded to his students</span></div>
		<div><strong>Over 225</strong><span>All-State students taught since 1997</span></div>
		<div><strong>Multiple</strong><span>lesson formats including private, group, classroom, clinic, and online instruction</span></div>
	</section>

	<section class="section section-intro">
		<p class="kicker">Lesson Paths</p>
		<h2>Focused instruction for the milestones that matter.</h2>
		<p class="lede">
			From the first notes on the horn to college audition preparation, each lesson is built
			around concrete musical growth and durable practice habits.
		</p>
	</section>

	<section class="section">
		<div class="grid">
			<article class="card photo-card">
				<img src={images.studioCase.src} alt={images.studioCase.alt} loading="lazy" />
				<div>
					<p class="kicker">Private Study</p>
					<h3>Clarinet Lessons</h3>
					<p>Audition preparation, fundamentals, tone, technique, and confidence for beginners through advanced players.</p>
					<a href="/clarinet-lessons/">View clarinet lessons</a>
				</div>
			</article>
			<article class="card photo-card">
				<img src={images.instruments.src} alt={images.instruments.alt} loading="lazy" />
				<div>
					<p class="kicker">Woodwind Lessons</p>
					<h3>Saxophone Lessons</h3>
					<p>Classical and jazz saxophone coaching with Robin's same goal-focused teaching approach.</p>
					<a href="/saxophone-lessons/">View saxophone lessons</a>
				</div>
			</article>
			<article class="card photo-card">
				<img src={images.bandListening.src} alt={images.bandListening.alt} loading="lazy" />
				<div>
					<p class="kicker">School Support</p>
					<h3>Band Director Mentoring</h3>
					<p>Clinics, sectionals, listening support, leadership training, and practical woodwind guidance.</p>
					<a href="/band-directors/">View school support</a>
				</div>
			</article>
		</div>
	</section>

	<section class="feature-band">
		<div class="section split">
			<div>
				<p class="kicker">Why Families Choose Robin</p>
				<h2>Serious musical growth, taught with patience, purpose, and passion.</h2>
				<p class="lede">
					Students come for better notes, stronger auditions, and a more reliable sound. They
					also learn personal discipline, creative problem solving, and the confidence
					to lead from their chair.
				</p>
				<div class="actions">
					<a class="button" href="/about-us/">Meet Robin Ryon</a>
					<a class="button secondary" href="/contact-us/">{site.primaryCta}</a>
				</div>
			</div>
			<div class="proof-grid">
				<article class="card proof-card">
					<h3>Audition preparation</h3>
					<p>All-County, All-State, chair placement, solo and ensemble, and college auditions.</p>
				</article>
				<article class="card proof-card">
					<h3>Whole-person teaching</h3>
					<p>Lessons connect tone, rhythm, technique, listening, practice habits, personal discipline, and confidence.</p>
				</article>
				<article class="card proof-card">
					<h3>Flexible formats</h3>
					<p>Robin teaches in Palm Bay, travels when available, works online, and supports school programs.</p>
				</article>
				<article class="card proof-card">
					<h3>Trusted experience</h3>
					<p>Robin has taught private students full time since 2006.</p>
				</article>
			</div>
		</div>
	</section>

	<section class="section split">
		<div>
			<p class="kicker">Pricing</p>
			<h2>Clear lesson options for students, families, and schools.</h2>
			<p class="lede">
				Families should not have to hunt for the basics. Choose the format that fits the
				student's goals, schedule, and location.
			</p>
			<div class="actions">
				<a class="button" href="/contact-us/">{site.primaryCta}</a>
				<a class="button secondary" href="/clarinet-lessons/">View lesson details</a>
			</div>
		</div>
		<div class="price-grid">
			<article class="card price-card">
				<p class="kicker">Palm Bay Lessons</p>
				<h3>$35 / 30 minutes</h3>
				<p>$70 per hour for lessons at Robin's Palm Bay teaching location.</p>
			</article>
			<article class="card price-card">
				<p class="kicker">Travel Lessons</p>
				<h3>$40 / 30 minutes</h3>
				<p>$80 per hour at your home, based on schedule and availability.</p>
			</article>
			<article class="card price-card">
				<p class="kicker">Online</p>
				<h3>Palm Bay rate</h3>
				<p>Zoom, Discord, or WhatsApp options for students outside Robin's local area.</p>
			</article>
		</div>
	</section>

	<section class="section">
		<div class="testimonial-band">
			<p class="kicker">Student and Parent Voices</p>
			<h2>Families value the blend of expertise, care, and high expectations.</h2>
			<div class="quote-scroller" aria-label="Scrolling student and parent reviews">
				<div class="quote-track">
					<blockquote>
						<p>Robin guided me from early fundamentals and strong practice habits to the life lessons needed for college and professional music.</p>
					</blockquote>
					<blockquote>
						<p>The time, thoughtfulness, and expertise Mr. Ryon demonstrates translates into ability, confidence, and a love for their instruments.</p>
					</blockquote>
					<blockquote>
						<p>Mr. Ryon knows how to prioritize the work needed for high achievement while building confidence and creativity.</p>
					</blockquote>
					<blockquote aria-hidden="true">
						<p>Robin guided me from early fundamentals and strong practice habits to the life lessons needed for college and professional music.</p>
					</blockquote>
					<blockquote aria-hidden="true">
						<p>The time, thoughtfulness, and expertise Mr. Ryon demonstrates translates into ability, confidence, and a love for their instruments.</p>
					</blockquote>
					<blockquote aria-hidden="true">
						<p>Mr. Ryon knows how to prioritize the work needed for high achievement while building confidence and creativity.</p>
					</blockquote>
				</div>
			</div>
			<div class="actions">
				<a class="button" href="/contact-us/">{site.primaryCta}</a>
				<a class="button secondary" href="/about-us/">Learn about Robin</a>
			</div>
		</div>
	</section>

	{
		Content && (
			<section class="band">
				<div class="content-page">
					<article>
						<Content />
					</article>
				</div>
			</section>
		)
	}
</BaseLayout>
