---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../lib/site';
---

<BaseLayout
	title="Thanks for reaching out"
	description="Thank you page for Florida Clarinet Studio contact form submissions."
>
	<section class="content-page thank-you-page">
		<p class="kicker">Message Sent</p>
		<h1>Thanks for reaching out.</h1>
		<p class="lede">
			Florida Clarinet Studio received your message. Mr. Ryon will follow up as soon as possible.
		</p>
		<div class="actions">
			<a class="button" href="/">Back home</a>
			<a class="button secondary" href={`tel:${site.phone.replaceAll('-', '')}`}>Call the studio</a>
		</div>
	</section>
</BaseLayout>
